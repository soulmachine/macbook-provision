GH_TOKEN=github_pat_xxxxx
TAILSCALE_AUTH_KEY=tskey-auth-xxxxx
TAILSCALE_API_ACCESS_TOKEN=tskey-api-xxxxx

# Optional — force the github role to use a specific SSH key when ~/.ssh holds
# several. Accepts an absolute path, a ~/ path, or a bare name resolved under
# ~/.ssh; the .pub suffix is optional. When unset, the preferred key by type is
# used (ed25519 > ecdsa > rsa). Leave commented out to keep the default.
#GITHUB_SSH_KEY=id_ed25519
